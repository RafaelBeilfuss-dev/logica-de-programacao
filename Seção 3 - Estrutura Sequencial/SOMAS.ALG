Algoritmo "soma"
// Calcula a soma de dois números inteiros
Var
   x, y, soma : inteiro
Inicio
   // Leitura dos valores
   escreval ("Digite o valor de X: ")
   leia(x)
   escreval ("Digite o valor de Y: ")
   leia(y)

   // Cálculo da soma
   soma <- (x+y)

   // Exibe o resultado
   escreval ("A soma de X e Y é", soma)
Fimalgoritmo