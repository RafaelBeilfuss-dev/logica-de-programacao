Algoritmo "consumo"
// Calcula o consumo mťdio (km/l)
Var
   ConsumoM, CombustivelG : real
   Distancia: inteiro
Inicio
   escreval ("CombustŪvel gasto: ")
   leia(CombustivelG)
   escreval ("Dist‚ncia percorrida: ")
   leia(Distancia)

   ConsumoM <- (Distancia/CombustivelG)
   // Calcula o consumo mťdio

   // Mostra o consumo mťdio com 3 casas decimais
   escreval ("O consumo mťdio: ", ConsumoM:8:3)
Fimalgoritmo